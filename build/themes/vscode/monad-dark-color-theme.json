  "tokenColors": [
    {
      "name": "Text base",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#EEF2F6"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#757575",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "keyword.other.using",
        "keyword.other.import"
      ],
      "settings": {
        "foreground": "#1E88C8"
      }
    },
    {
      "name": "Keyword \u2014 control flow",
      "scope": [
        "keyword.control.flow",
        "keyword.control.return",
        "keyword.control.trycatch"
      ],
      "settings": {
        "foreground": "#1E88C8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword \u2014 operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#B6BFCC"
      }
    },
    {
      "name": "Keyword \u2014 logical/comparison",
      "scope": [
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.assignment"
      ],
      "settings": {
        "foreground": "#1E88C8"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#6EAD45"
      }
    },
    {
      "name": "String \u2014 regexp",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#84B961"
      }
    },
    {
      "name": "String \u2014 escape",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#60B6DC"
      }
    },
    {
      "name": "String \u2014 interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.interpolation"
      ],
      "settings": {
        "foreground": "#2B9ED1"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#D7A12A"
      }
    },
    {
      "name": "Boolean / built-in",
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#D7A12A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constant \u2014 other",
      "scope": [
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#FFEB3B"
      }
    },
    {
      "name": "Function definition",
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function"
      ],
      "settings": {
        "foreground": "#2B9ED1"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "meta.function-call entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#60B6DC"
      }
    },
    {
      "name": "Function parameter",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#B6BFCC",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Type / class",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.enum",
        "entity.name.interface",
        "entity.name.trait",
        "support.type",
        "support.class",
        "support.type.primitive"
      ],
      "settings": {
        "foreground": "#4BA0D3"
      }
    },
    {
      "name": "Inherited class",
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#4BA0D3",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#EEF2F6"
      }
    },
    {
      "name": "Variable \u2014 language (this/self)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#1E88C8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#B6BFCC"
      }
    },
    {
      "name": "Object key / attribute name",
      "scope": [
        "meta.object-literal.key",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#2B9ED1"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#757575"
      }
    },
    {
      "name": "Brackets",
      "scope": [
        "punctuation.definition.brackets",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#B6BFCC"
      }
    },
    {
      "name": "Decorator",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#BF73CC"
      }
    },
    {
      "name": "Module / namespace",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.module"
      ],
      "settings": {
        "foreground": "#2B9ED1"
      }
    },
    {
      "name": "Import path",
      "scope": [
        "meta.import string",
        "meta.require string"
      ],
      "settings": {
        "foreground": "#6EAD45"
      }
    },
    {
      "name": "HTML tag",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#1E88C8"
      }
    },
    {
      "name": "HTML attribute",
      "scope": [
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#2B9ED1"
      }
    },
    {
      "name": "HTML attribute value",
      "scope": [
        "string.quoted.html",
        "meta.attribute.html string"
      ],
      "settings": {
        "foreground": "#6EAD45"
      }
    },
    {
      "name": "HTML entity",
      "scope": [
        "constant.character.entity"
      ],
      "settings": {
        "foreground": "#D7A12A"
      }
    },
    {
      "name": "HTML/XML tag punctuation",
      "scope": [
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#404244"
      }
    },
    {
      "name": "CSS selector",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#1E88C8"
      }
    },
    {
      "name": "CSS property",
      "scope": [
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#2B9ED1"
      }
    },
    {
      "name": "CSS value",
      "scope": [
        "meta.property-value.css",
        "support.constant.property-value.css"
      ],
      "settings": {
        "foreground": "#B6BFCC"
      }
    },
    {
      "name": "CSS color / unit",
      "scope": [
        "constant.other.color.rgb-value.css",
        "constant.numeric.css",
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#D7A12A"
      }
    },
    {
      "name": "CSS custom property",
      "scope": [
        "variable.css",
        "variable.scss",
        "variable.other.less"
      ],
      "settings": {
        "foreground": "#FFEB3B"
      }
    },
    {
      "name": "CSS at-rule",
      "scope": [
        "keyword.control.at-rule"
      ],
      "settings": {
        "foreground": "#BF73CC"
      }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#1E88C8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#EEF2F6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#EEF2F6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#6EAD45"
      }
    },
    {
      "name": "Markdown link",
      "scope": [
        "markup.underline.link",
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#2B9ED1"
      }
    },
    {
      "name": "Markdown blockquote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#757575",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSON property key",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#2B9ED1"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#D64C45"
      }
    },
    {
      "name": "Deprecated",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#D7A12A",
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#4BA0D3",
    "class.declaration": {
      "foreground": "#4BA0D3",
      "bold": true
    },
    "interface": "#4BA0D3",
    "enum": "#4BA0D3",
    "enumMember": "#FFEB3B",
    "struct": "#4BA0D3",
    "typeParameter": "#4BA0D3",
    "function": "#2B9ED1",
    "function.declaration": {
      "foreground": "#2B9ED1"
    },
    "method": "#60B6DC",
    "method.declaration": {
      "foreground": "#60B6DC"
    },
    "property": "#B6BFCC",
    "property.declaration": {
      "foreground": "#B6BFCC"
    },
    "variable": "#EEF2F6",
    "variable.defaultLibrary": "#1E88C8",
    "parameter": {
      "foreground": "#B6BFCC",
      "italic": true
    },
    "keyword": "#1E88C8",
    "modifier": "#1E88C8",
    "number": "#D7A12A",
    "string": "#6EAD45",
    "regexp": "#84B961",
    "namespace": "#2B9ED1",
    "decorator": "#BF73CC",
    "comment": {
      "foreground": "#757575",
