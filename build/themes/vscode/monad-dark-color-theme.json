  "tokenColors": [
    {
      "name": "Text base",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#E0E0E0"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#757575",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier",
        "keyword.other.using",
        "keyword.other.import"
      ],
      "settings": {
        "foreground": "#03A9F4"
      }
    },
    {
      "name": "Keyword \u2014 control flow",
      "scope": [
        "keyword.control.flow",
        "keyword.control.return",
        "keyword.control.trycatch"
      ],
      "settings": {
        "foreground": "#03A9F4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword \u2014 operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#B0B0B0"
      }
    },
    {
      "name": "Keyword \u2014 logical/comparison",
      "scope": [
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.assignment"
      ],
      "settings": {
        "foreground": "#03A9F4"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#8BC34A"
      }
    },
    {
      "name": "String \u2014 regexp",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#4CAF50"
      }
    },
    {
      "name": "String \u2014 escape",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#4DD0E1"
      }
    },
    {
      "name": "String \u2014 interpolation",
      "scope": [
        "meta.interpolation",
        "punctuation.definition.interpolation"
      ],
      "settings": {
        "foreground": "#00BCD4"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#FFC107"
      }
    },
    {
      "name": "Boolean / built-in",
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#FFC107",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constant \u2014 other",
      "scope": [
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#FFEB3B"
      }
    },
    {
      "name": "Function definition",
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function"
      ],
      "settings": {
        "foreground": "#00BCD4"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "meta.function-call entity.name.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#4DD0E1"
      }
    },
    {
      "name": "Function parameter",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#B0B0B0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Type / class",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.enum",
        "entity.name.interface",
        "entity.name.trait",
        "support.type",
        "support.class",
        "support.type.primitive"
      ],
      "settings": {
        "foreground": "#29B6F6"
      }
    },
    {
      "name": "Inherited class",
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#29B6F6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#E0E0E0"
      }
    },
    {
      "name": "Variable \u2014 language (this/self)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#03A9F4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#B0B0B0"
      }
    },
    {
      "name": "Object key / attribute name",
      "scope": [
        "meta.object-literal.key",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#00BCD4"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#757575"
      }
    },
    {
      "name": "Brackets",
      "scope": [
        "punctuation.definition.brackets",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#B0B0B0"
      }
    },
    {
      "name": "Decorator",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#CE93D8"
      }
    },
    {
      "name": "Module / namespace",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.module"
      ],
      "settings": {
        "foreground": "#00BCD4"
      }
    },
    {
      "name": "Import path",
      "scope": [
        "meta.import string",
        "meta.require string"
      ],
      "settings": {
        "foreground": "#8BC34A"
      }
    },
    {
      "name": "HTML tag",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#03A9F4"
      }
    },
    {
      "name": "HTML attribute",
      "scope": [
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#00BCD4"
      }
    },
    {
      "name": "HTML attribute value",
      "scope": [
        "string.quoted.html",
        "meta.attribute.html string"
      ],
      "settings": {
        "foreground": "#8BC34A"
      }
    },
    {
      "name": "HTML entity",
      "scope": [
        "constant.character.entity"
      ],
      "settings": {
        "foreground": "#FFC107"
      }
    },
    {
      "name": "HTML/XML tag punctuation",
      "scope": [
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#434343"
      }
    },
    {
      "name": "CSS selector",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#03A9F4"
      }
    },
    {
      "name": "CSS property",
      "scope": [
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#00BCD4"
      }
    },
    {
      "name": "CSS value",
      "scope": [
        "meta.property-value.css",
        "support.constant.property-value.css"
      ],
      "settings": {
        "foreground": "#B0B0B0"
      }
    },
    {
      "name": "CSS color / unit",
      "scope": [
        "constant.other.color.rgb-value.css",
        "constant.numeric.css",
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#FFC107"
      }
    },
    {
      "name": "CSS custom property",
      "scope": [
        "variable.css",
        "variable.scss",
        "variable.other.less"
      ],
      "settings": {
        "foreground": "#FFEB3B"
      }
    },
    {
      "name": "CSS at-rule",
      "scope": [
        "keyword.control.at-rule"
      ],
      "settings": {
        "foreground": "#CE93D8"
      }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#03A9F4",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#E0E0E0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#E0E0E0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#8BC34A"
      }
    },
    {
      "name": "Markdown link",
      "scope": [
        "markup.underline.link",
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#00BCD4"
      }
    },
    {
      "name": "Markdown blockquote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#757575",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSON property key",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#00BCD4"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#F44336"
      }
    },
    {
      "name": "Deprecated",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#FFC107",
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#29B6F6",
    "class.declaration": {
      "foreground": "#29B6F6",
      "bold": true
    },
    "interface": "#29B6F6",
    "enum": "#29B6F6",
    "enumMember": "#FFEB3B",
    "struct": "#29B6F6",
    "typeParameter": "#29B6F6",
    "function": "#00BCD4",
    "function.declaration": {
      "foreground": "#00BCD4"
    },
    "method": "#4DD0E1",
    "method.declaration": {
      "foreground": "#4DD0E1"
    },
    "property": "#B0B0B0",
    "property.declaration": {
      "foreground": "#B0B0B0"
    },
    "variable": "#E0E0E0",
    "variable.defaultLibrary": "#03A9F4",
    "parameter": {
      "foreground": "#B0B0B0",
      "italic": true
    },
    "keyword": "#03A9F4",
    "modifier": "#03A9F4",
    "number": "#FFC107",
    "string": "#8BC34A",
    "regexp": "#4CAF50",
    "namespace": "#00BCD4",
    "decorator": "#CE93D8",
    "comment": {
      "foreground": "#757575",
