    "tab.activeBorder": "#028FCF",
    "tab.activeBorderTop": "#00000000",
    "tab.unfocusedActiveBorder": "#c6c6c6",
    "tab.hoverBackground": "#e8e8e8",
    "tab.hoverForeground": "#161616",
