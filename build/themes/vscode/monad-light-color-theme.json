    "titleBar.activeBackground": "#e8e8e8",
    "titleBar.activeForeground": "#161616",
    "titleBar.inactiveBackground": "#e8e8e8",
    "titleBar.inactiveForeground": "#8d8d8d",
    "titleBar.border": "#c6c6c6",
    "editorGroupHeader.tabsBackground": "#f4f4f4",
    "editorGroupHeader.noTabsBackground": "#f4f4f4",
