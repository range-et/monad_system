    "statusBar.noFolderBackground": "#e8e8e8",
    "statusBar.noFolderForeground": "#525252",
    "statusBar.debuggingBackground": "#E5AD06",
    "statusBar.debuggingForeground": "#ffffff",
    "statusBarItem.errorBackground": "#AA2E25",
