    "panelTitle.activeBorder": "#1973AA",
    "terminal.background": "#F2F4F7",
    "terminal.foreground": "#141A22",
    "terminal.border": "#BCC6D2",
    "terminal.selectionBackground": "#1973AA30",
    "terminalCursor.background": "#F2F4F7",
    "terminalCursor.foreground": "#1973AA",
    "terminal.ansiBlack": "#141A22",
    "terminal.ansiRed": "#953530",
    "terminal.ansiGreen": "#47702C",
    "terminal.ansiYellow": "#C19025",
    "terminal.ansiBlue": "#1973AA",
    "terminal.ansiMagenta": "#6D1B7B",
    "terminal.ansiCyan": "#1B6687",
    "terminal.ansiWhite": "#4F5A69",
    "terminal.ansiBrightBlack": "#7E8998",
    "terminal.ansiBrightRed": "#D64C45",
    "terminal.ansiBrightGreen": "#6EAD45",
    "terminal.ansiBrightYellow": "#D7A12A",
    "terminal.ansiBrightBlue": "#1E88C8",
    "terminal.ansiBrightMagenta": "#9C27B0",
    "terminal.ansiBrightCyan": "#2B9ED1",
    "terminal.ansiBrightWhite": "#ffffff",
    "input.background": "#ffffff",
    "input.foreground": "#141A22",
    "input.border": "#BCC6D2",
    "input.placeholderForeground": "#7E8998",
    "inputOption.activeBorder": "#1973AA",
    "inputOption.activeBackground": "#1973AA20",
    "inputValidation.infoBorder": "#1B6687",
    "inputValidation.infoBackground": "#1B66871a",
    "inputValidation.warningBorder": "#C19025",
    "inputValidation.warningBackground": "#C190251a",
    "inputValidation.errorBorder": "#953530",
    "inputValidation.errorBackground": "#9535301a",
    "dropdown.background": "#ffffff",
    "dropdown.foreground": "#141A22",
    "dropdown.border": "#BCC6D2",
    "button.background": "#1973AA",
    "button.foreground": "#FFFFFF",
    "button.hoverBackground": "#166696",
    "button.secondaryBackground": "#E3E8EE",
    "button.secondaryForeground": "#141A22",
    "button.secondaryHoverBackground": "#BCC6D2",
    "badge.background": "#1973AA",
    "badge.foreground": "#FFFFFF",
    "scrollbarSlider.background": "#BCC6D280",
    "scrollbarSlider.hoverBackground": "#BCC6D2CC",
    "scrollbarSlider.activeBackground": "#1973AA60",
    "progressBar.background": "#1973AA",
    "diffEditor.insertedTextBackground": "#47702C20",
    "diffEditor.removedTextBackground": "#95353020",
    "diffEditor.insertedLineBackground": "#47702C12",
    "diffEditor.removedLineBackground": "#95353012",
    "gitDecoration.addedResourceForeground": "#47702C",
    "gitDecoration.modifiedResourceForeground": "#1973AA",
    "gitDecoration.deletedResourceForeground": "#953530",
    "gitDecoration.untrackedResourceForeground": "#47702C",
    "gitDecoration.ignoredResourceForeground": "#7E8998",
    "gitDecoration.conflictingResourceForeground": "#C19025",
    "focusBorder": "#1973AA",
    "foreground": "#141A22",
    "widget.shadow": "#00000018",
    "selection.background": "#1973AA30",
    "icon.foreground": "#4F5A69",
    "disabledForeground": "#7E8998",
    "errorForeground": "#953530",
    "descriptionForeground": "#7E8998",
    "quickInput.background": "#ffffff",
    "quickInput.foreground": "#141A22",
    "quickInputList.focusBackground": "#E3E8EE",
    "quickInputList.focusForeground": "#141A22",
    "extensionButton.prominentBackground": "#1973AA",
    "extensionButton.prominentForeground": "#FFFFFF",
    "extensionButton.prominentHoverBackground": "#166696",
    "settings.modifiedItemIndicator": "#1973AA",
    "settings.focusedRowBackground": "#F2F4F7",
    "settings.rowHoverBackground": "#F2F4F7",
    "merge.currentHeaderBackground": "#47702C30",
    "merge.currentContentBackground": "#47702C15",
    "merge.incomingHeaderBackground": "#1973AA30",
    "merge.incomingContentBackground": "#1973AA15",
    "merge.commonHeaderBackground": "#C1902530",
    "merge.commonContentBackground": "#C1902515",
    "charts.red": "#953530",
    "charts.blue": "#1973AA",
    "charts.yellow": "#C19025",
    "charts.green": "#47702C",
    "charts.purple": "#6D1B7B",
    "charts.foreground": "#141A22",
    "charts.lines": "#BCC6D2"
  },
  "tokenColors": [
    {
      "name": "Text base",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#141A22"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7E8998",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#1973AA"
      }
    },
    {
      "name": "Keyword \u2014 control flow",
      "scope": [
        "keyword.control.flow",
        "keyword.control.return"
      ],
      "settings": {
        "foreground": "#1973AA",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword \u2014 operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#4F5A69"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#47702C"
      }
    },
    {
      "name": "String \u2014 regexp",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#47702C"
      }
    },
    {
      "name": "String \u2014 escape",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#1B6687"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#C19025"
      }
    },
    {
      "name": "Boolean / built-in",
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#C19025",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constant \u2014 other",
      "scope": [
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#D8C732"
      }
    },
    {
      "name": "Function definition",
      "scope": [
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#1B6687"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#1B6687"
      }
    },
    {
      "name": "Function parameter",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#4F5A69",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Type / class",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#135882"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#141A22"
      }
    },
    {
      "name": "Variable \u2014 language",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#1973AA",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#4F5A69"
      }
    },
    {
      "name": "Object key / attribute",
      "scope": [
        "meta.object-literal.key",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#1B6687"
      }
    },
    {
      "name": "Decorator",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#6D1B7B"
      }
    },
    {
      "name": "HTML tag",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#1973AA"
      }
    },
    {
      "name": "HTML attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#1B6687"
      }
    },
    {
      "name": "CSS selector",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "#1973AA"
      }
    },
    {
      "name": "CSS property",
      "scope": [
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#1B6687"
      }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#1973AA",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#47702C"
      }
    },
    {
      "name": "Markdown link",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#1B6687"
      }
    },
    {
      "name": "JSON property key",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#1B6687"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#953530"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#135882",
    "interface": "#135882",
    "enum": "#135882",
    "enumMember": "#D8C732",
    "function": "#1B6687",
    "method": "#1B6687",
    "property": "#4F5A69",
    "variable": "#141A22",
    "variable.defaultLibrary": "#1973AA",
    "parameter": {
      "foreground": "#4F5A69",
      "italic": true
    },
    "keyword": "#1973AA",
    "number": "#C19025",
    "string": "#47702C",
    "namespace": "#1B6687",
    "decorator": "#6D1B7B",
    "comment": {
      "foreground": "#7E8998",
      "italic": true
    },
    "type": "#135882"
  }
}